{
  "name": "gull",
  "version": "1.2.28",
  "description": "A typography-first e-book reader for macOS",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "npm run dev",
    "electron": "electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && dotenv -- electron-builder --mac",
    "preview": "vite preview",
    "build:icon": "node scripts/build-icon.js",
    "changelog": "node scripts/generate-changelog.js",
    "check": "node --check main.js && node --check preload.js && node --check lib/book-content.js && node --check lib/epub-parser.js && node --check lib/epub-parser-worker.js && node --check src/lib/theme.mjs && node --check src/lib/highlight-anchor.mjs && node --check src/lib/book-order.mjs",
    "test": "node --test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "me.limboy.gull",
    "productName": "Gull",
    "fileAssociations": [
      {
        "ext": "epub",
        "name": "EPUB Document",
        "description": "EPUB e-book file",
        "role": "Viewer",
        "mimeType": "application/epub+zip"
      },
      {
        "ext": "mobi",
        "name": "MOBI Document",
        "description": "MOBI e-book file",
        "role": "Viewer",
        "mimeType": "application/x-mobipocket-ebook"
      },
      {
        "ext": "azw3",
        "name": "AZW3 Document",
        "description": "Amazon Kindle KF8 e-book file",
        "role": "Viewer",
        "mimeType": "application/vnd.amazon.mobi8-ebook"
      },
      {
        "ext": "azw",
        "name": "AZW Document",
        "description": "Amazon Kindle e-book file",
        "role": "Viewer",
        "mimeType": "application/vnd.amazon.ebook"
      },
      {
        "ext": "prc",
        "name": "PRC Document",
        "description": "Mobipocket e-book file",
        "role": "Viewer",
        "mimeType": "application/x-mobipocket-ebook"
      }
    ],
    "mac": {
      "category": "public.app-category.books",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "minimumSystemVersion": "12.0",
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "notarize": true
    },
    "afterPack": "scripts/afterPack.js",
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*.js",
      "dist/index.html",
      "dist/assets/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "limboy",
        "repo": "gull",
        "releaseType": "release"
      }
    ],
    "releaseInfo": {
      "releaseNotesFile": "RELEASENOTES.md"
    }
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/open-sans": "^5.2.7",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.8.0",
    "postcss": "^8.5.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@lingo-reader/mobi-parser": "^0.4.6",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "adm-zip": "^0.5.16",
    "cheerio": "^1.2.0",
    "electron-updater": "^6.8.3"
  }
}

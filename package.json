{
  "name": "yara",
  "version": "1.0.0",
  "description": "A pure EPUB reader",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "npm run dev",
    "electron": "electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --mac",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.yara.reader",
    "productName": "Yara",
    "fileAssociations": [
      {
        "ext": "epub",
        "name": "EPUB Document",
        "description": "EPUB e-book file",
        "role": "Viewer",
        "mimeType": "application/epub+zip",
        "uti": "org.idpf.epub-container"
      }
    ],
    "mac": {
      "category": "public.app-category.books",
      "target": "dmg"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "logo.png"
    ]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/open-sans": "^5.2.7",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "adm-zip": "^0.5.16",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1"
  }
}
